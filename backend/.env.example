# TraceLearn backend — environment template.
# Copy to `.env` (which is git-ignored) and fill in real values LOCALLY.
# NEVER commit the real .env or paste the API key anywhere shared.

# Set to false to use the real LLM. Defaults to true (offline mock demo) if unset.
MOCK_LLM=false

# The team's LMU AI endpoint — a native Anthropic Messages API.
# Base URL only (no trailing /v1/messages — the client appends it).
ANTHROPIC_BASE_URL=https://api.lmuai.com

# The shared team API key. Paste locally only; git-ignored via .env.
ANTHROPIC_API_KEY=<paste-key-in-your-local-.env-never-commit>

# LMU serves three claude tiers (confirmed 2026-07-21). MODEL_NAME is the
# default; the MODEL_* below are the per-task routing ids used in A2.
MODEL_NAME=claude-sonnet-4-6
MODEL_GENERATION=claude-haiku-4-5-20251001
MODEL_PLAN=claude-sonnet-4-6
MODEL_REPLAN=claude-opus-4-8

# Bounded guardrails for the live call (optional; sensible defaults in config.py).
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Where uploaded documents are stored on disk (Member C — item 9).
UPLOAD_DIR=./uploads
